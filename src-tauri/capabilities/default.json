{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for Pharaoh desktop app",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:default",
    "shell:allow-open",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-read-file",
    "fs:scope-home-recursive",
    "fs:scope-applocaldata-recursive",
    "fs:allow-write-text-file",
    "fs:allow-mkdir",
    "fs:allow-read-dir",
    "fs:allow-exists",
    "fs:allow-rename",
    "fs:allow-remove",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save"
  ]
}
